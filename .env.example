# ─────────────────────────────────────────────────────────────────────────────
# Inspire2Live Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>   # server-side only — keep secret!

# ── Resend (required for email notifications) ─────────────────────────────────
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── App ───────────────────────────────────────────────────────────────────────
# For local development use http://localhost:3000
# For production use your Vercel URL exactly (no trailing slash),
# e.g. https://inspire2live-platform.vercel.app
NEXT_PUBLIC_APP_URL=https://<your-vercel-url>
NEXT_PUBLIC_APP_NAME=Inspire2Live Platform

# ── Cron (required for scheduled jobs) ───────────────────────────────────────
# Generate a secure random secret, e.g.:  openssl rand -base64 32
CRON_SECRET=<your-cron-secret>

# ── WhatsApp Cloud API (required for the Communications WhatsApp inbox) ───────
# Get these from: https://developers.facebook.com → your App → WhatsApp → API Setup
# WHATSAPP_VERIFY_TOKEN: a string you choose yourself; enter the same value when
#   configuring the webhook callback URL in the Meta dashboard.
# WHATSAPP_APP_SECRET: from App Settings → Basic. Verifies the
#   x-hub-signature-256 header on incoming webhook calls.
# WHATSAPP_ACCESS_TOKEN: a temporary (24h) or System User (long-lived) token —
#   server-side only, never exposed to the browser.
# WHATSAPP_PHONE_NUMBER_ID / WHATSAPP_BUSINESS_ACCOUNT_ID: from API Setup.
WHATSAPP_VERIFY_TOKEN=<your-chosen-verify-token>
WHATSAPP_APP_SECRET=<your-meta-app-secret>
WHATSAPP_ACCESS_TOKEN=<your-whatsapp-access-token>   # server-side only — keep secret!
WHATSAPP_PHONE_NUMBER_ID=<your-phone-number-id>
WHATSAPP_BUSINESS_ACCOUNT_ID=<your-whatsapp-business-account-id>

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Enable features per deployment phase. Start with all false for MVP.
NEXT_PUBLIC_FEATURE_CONGRESS=false
NEXT_PUBLIC_FEATURE_HUBS=false
NEXT_PUBLIC_FEATURE_PARTNERS=false
